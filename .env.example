VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-browser-safe-publishable-key
# Use supabase for the hosted mobile pilot. Local remains the development default.
VITE_WORKSPACE_REPOSITORY=local
# Never place a service-role or secret key in any VITE_ variable.
# Browser smoke tests use a random localhost-only owner created by:
# node scripts/browser-test-owner.mjs
# Never commit the emitted credentials. Remove the owner after the test with:
# node scripts/browser-test-owner.mjs delete <user-id>
# Start the browser-test app against local Supabase, ignoring any hosted .env.local:
# node scripts/browser-test-server.mjs
# Repository-owned E2E manages both helpers automatically:
# npm run test:e2e
# npm run test:e2e:mobile

# Server-only Supabase Edge Function secrets. Set with `supabase secrets set`;
# never prefix these with VITE_ and never commit real values.
# PROCUREMENT_LIVE_RESEARCH_ENABLED=true
# OPENAI_API_KEY=replace-with-server-secret
# OPENAI_WEBHOOK_SECRET=replace-with-server-webhook-signing-secret
# OPENAI_PROCUREMENT_MODEL=gpt-5.6
# PROCUREMENT_LIVE_DAILY_LIMIT=5
